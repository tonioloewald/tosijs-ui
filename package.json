{
  "name": "tosijs-ui",
  "version": "1.7.0-beta.3",
  "description": "simple robust web-components for use with tosijs or anything else",
  "scripts": {
    "start": "bun --watch bin/dev.ts",
    "tls": "bash tls/create-dev-certs.sh",
    "build": "bun bin/dev.ts --build-only",
    "book": "bun bin/build-book.ts",
    "og": "bun bin/generate-og.ts",
    "test-browser": "bun bin/dev.ts --test",
    "format": "bun eslint src demo --fix && bun prettier --write .",
    "tests": "bun test && bun playwright test",
    "latest": "rm -rf node_modules bun.lock && bun update"
  },
  "keywords": [
    "tosijs",
    "ui",
    "ux",
    "user interface",
    "gui",
    "widgets",
    "web-components",
    "component library"
  ],
  "author": "Tonio Loewald",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonioloewald/xinjs-ui.git"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.19.12",
    "@types/react": "^19.2.14",
    "bun-types": "latest",
    "chokidar": "^4.0.3",
    "eslint": "^10",
    "globals": "^17.6.0",
    "happy-dom": "^20.7.0",
    "playwright": "^1.58.2",
    "prettier": "^2.8.8",
    "tjs-lang": "0.10.1",
    "tosijs": "^1.6.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "happy-dom": "^20.7.0",
    "marked": "^16.4.2",
    "tjs-lang": "^0.10.1",
    "tosijs": "^1.6.9"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    },
    "happy-dom": {
      "optional": true
    },
    "tjs-lang": {
      "optional": true
    }
  },
  "files": [
    "/dist",
    "/bin/docs.ts",
    "/bin/make-icon-data.js",
    "/tls/create-dev-certs.sh",
    "/LICENSE",
    "/README.md",
    "/CHANGELOG.md",
    "/llms.txt"
  ],
  "bin": {
    "tosijs-make-icons": "bin/make-icon-data.js",
    "tosijs-dev-certs": "tls/create-dev-certs.sh"
  },
  "source": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./site": {
      "types": "./dist/doc-system/site/index.d.ts",
      "import": "./dist/doc-system/site/index.js",
      "default": "./dist/doc-system/site/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "default": "./dist/icons.js"
    },
    "./code-editor": {
      "types": "./dist/code-editor.d.ts",
      "import": "./dist/code-editor.js",
      "default": "./dist/code-editor.js"
    },
    "./live-example": {
      "types": "./dist/live-example/index.d.ts",
      "import": "./dist/live-example/index.js",
      "default": "./dist/live-example/index.js"
    },
    "./doc-browser": {
      "types": "./dist/doc-browser.d.ts",
      "import": "./dist/doc-browser.js",
      "default": "./dist/doc-browser.js"
    },
    "./diff": {
      "types": "./dist/diff.d.ts",
      "import": "./dist/diff.js",
      "default": "./dist/diff.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4"
  }
}
